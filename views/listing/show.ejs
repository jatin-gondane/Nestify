<% layout('../layouts/boilerplate.ejs') %>

<script>
  let apiKeyMap = "<%=process.env.Map_Api_Key %>";
  let coordinate = "<%- JSON.stringify(data.geometry.coordinates) %>";
</script>

<div class="container-fluid px-3 px-md-4">
  <div class="row mt-3">
    <!-- Title -->
    <div class="col-12 col-lg-10 offset-lg-3">
      <h3 class="mb-3"><b><%= data.title %></b></h3>
    </div>

    <!-- Main Card -->
    <div class="col-12 col-lg-6 offset-lg-3">
      <div class="card show-card">
        <img 
          src="<%= data.image.url %>" 
          class="card-img-top show-img" 
          alt="listing_image"
        />

        <div class="card-body mt-2">
          <p class="card-text">
            <i>owned by : <%= data.owner.username %></i><br>
            <%= data.description %><br />
            &#8377; <%= data.price.toLocaleString("en-IN") %><br />
            <%= data.location %><br />
            <%= data.country %>
          </p>
        </div>
      </div>

      <!-- Action Buttons -->
      <% if (existingUser && existingUser._id.equals(data.owner._id)) { %>
        <div class="d-flex flex-column flex-sm-row gap-2 mt-3">
          <a href="/listing/<%= data.id %>" class="btn btn-danger px-4">Edit</a>
          <form action="/listing/<%= data.id %>?_method=DELETE" method="POST">
            <button type="submit" class="btn bott btn-dark px-4 w-100">Delete</button>
          </form>
        </div>
      <% } %>
      
      <% if (existingUser && !existingUser._id.equals(data.owner._id)) { %>
        <form action="/listing/<%= data.id %>/view/enquiry" method="POST" class="mt-3">
          <button type="submit" id="book" class="btn bott btn-primary px-4 w-100 w-sm-auto">Book</button>
        </form>
      <% } %>
    </div>
  </div>

  <hr class="my-4">

  <!-- Review Form Section -->
  <% if (existingUser) { %>
  <div class="row">
    <div class="col-12 col-lg-8 offset-lg-2">
      <h4 class="mb-3">Leave a Review</h4>

      <form action="/listing/<%= data.id %>/review" method="post" id="reviewForm" class="p-3 p-md-4 border rounded shadow-sm bg-white needs-validation" novalidate>

        <!-- Rating -->
        <div class="mb-3">
          <label class="form-label fw-semibold">Rating</label>
          <fieldset class="starability-slot">
            <legend>First rating:</legend>
            <input type="radio" id="no-rate" class="input-no-rate" name="reviews[rating]" value="0" checked aria-label="No rating." />
            <input type="radio" id="first-rate1" name="reviews[rating]" value="1" />
            <label for="first-rate1" title="Terrible">1 star</label>
            <input type="radio" id="first-rate2" name="reviews[rating]" value="2" />
            <label for="first-rate2" title="Not good">2 stars</label>
            <input type="radio" id="first-rate3" name="reviews[rating]" value="3" />
            <label for="first-rate3" title="Average">3 stars</label>
            <input type="radio" id="first-rate4" name="reviews[rating]" value="4" />
            <label for="first-rate4" title="Very good">4 stars</label>
            <input type="radio" id="first-rate5" name="reviews[rating]" value="5" />
            <label for="first-rate5" title="Amazing">5 stars</label>
          </fieldset>
        </div>

        <!-- Comment -->
        <div class="mb-3">
          <label class="form-label fw-semibold">Comment</label>
          <textarea name="reviews[Comment]" class="form-control" rows="4" placeholder="Write your review..." required></textarea>
        </div>

        <!-- Submit -->
        <button type="submit" class="btn btn-primary w-100">
          Submit Review
        </button>
      </form>
    </div>
  </div>
  <hr class="my-4">
  <% } %>

  <!-- Reviews Display Section -->
  <% if (data.reviews.length > 0) { %>
  <div class="row">
    <div class="col-12 col-lg-10 offset-lg-1">
      <h4 class="mb-3"><b>All Reviews</b></h4>
      <div class="row g-3">
        <% for(review of data.reviews) { %>
        <div class="col-12 col-md-6 col-lg-4">
          <div class="card h-100" style="border:1px solid #100f0f !important;">
            <div class="card-body">
              <h5 class="card-title">@<%= review.author.username %></h5>
              <p class="card-text starability-result" data-rating="<%= review.rating %>"></p>
              <p class="card-text"><%= review.Comment %></p>
            </div>
            <% if (existingUser && existingUser._id.equals(review.author._id)) { %>
            <div class="card-footer bg-transparent border-0">
              <form action="/listing/<%= data._id %>/review/<%= review._id %>/delete?_method=DELETE" method="post">
                <button class="btn btn-danger w-100">Delete</button>
              </form>
            </div>
            <% } %>
          </div>
        </div>
        <% } %>
      </div>
    </div>
  </div>
  <hr class="my-4">
  <% } %>

  <!-- Map Section -->
  <div class="row mb-4">
    <div class="col-12 col-lg-8 offset-lg-2">
      <h3 class="mb-3">Where you will be...</h3>
      <div id="map" style="height: 400px; width: 100%;"></div>
    </div>
  </div>
</div>

<script src="/js/map.js"></script>
<script>
  let bookButton = document.getElementById("book");
  bookButton.addEventListener('click',()=>{
    bookButton.innerHTML = `booking... <span class="spinner-border spinner-border-sm"></span>`;
  })
</script>